# ============================================================
# AI Video Agent — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- LLM Provider -------------------------------------------
# Options: "deepseek" or "ollama"
LLM_PROVIDER=deepseek

# --- DeepSeek API -------------------------------------------
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Model: "deepseek-chat" (V3) or "deepseek-reasoner" (R1)
DEEPSEEK_MODEL=deepseek-chat

# --- Ollama (Vast.ai instance) ------------------------------
OLLAMA_BASE_URL=http://your-vastai-instance-ip:11434/v1
OLLAMA_MODEL=gemma3:27b

# --- API Server ---------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# --- Optional: Generation Settings --------------------------
# Max scenes to generate per video
MAX_SCENES=10
# Default video duration in seconds
DEFAULT_DURATION=120
# Temperature for creative agents (0.0 - 1.0)
CREATIVE_TEMPERATURE=0.8
# Temperature for structured output agents (0.0 - 1.0)  
STRUCTURED_TEMPERATURE=0.4
